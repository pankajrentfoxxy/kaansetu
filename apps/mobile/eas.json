{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "distribution": "internal",
      "android": { "buildType": "apk", "gradleCommand": ":app:assembleDebug" },
      "env": { "APP_ENV": "development" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "APP_ENV": "staging" }
    },
    "production": {
      "distribution": "store",
      "android": { "buildType": "app-bundle" },
      "env": { "APP_ENV": "production" }
    }
  }
}
